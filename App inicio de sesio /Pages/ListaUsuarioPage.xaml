<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyApp.Pages.ListaUsuariosPage"
             Title="Usuarios Registrados"
             BackgroundColor="#F5F5F5">
    
    <StackLayout>
        <!-- Título -->
        <Label Text="SELECCIONA UN USUARIO"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="#2196F3"
               Margin="0,20,0,20"/>
        
        <!-- Lista simple como la de Windows -->
        <ListView x:Name="listaUsuarios"
                  ItemTapped="listaUsuarios_ItemTapped"
                  SeparatorVisibility="Default"
                  RowHeight="70"
                  Margin="10,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Frame Margin="5,2" Padding="10" CornerRadius="5" BackgroundColor="White">
                            <StackLayout Orientation="Horizontal" Spacing="10">
                                <Label Text="👤" FontSize="24" VerticalOptions="Center"/>
                                <StackLayout Spacing="0">
                                    <Label Text="{Binding NombreUsuario}" 
                                           FontSize="18" 
                                           FontAttributes="Bold"
                                           TextColor="#333333"/>
                                    <Label Text="{Binding Rol}" 
                                           FontSize="14"
                                           TextColor="#666666"/>  <!-- 👈 CORREGIDO -->
                                </StackLayout>
                            </StackLayout>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackLayout>
    
</ContentPage>