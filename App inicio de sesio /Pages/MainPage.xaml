<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyApp.Pages.MainPage"
             BackgroundColor="#F5F5F5">
    
    <ScrollView>
        <StackLayout Padding="20" Spacing="15">
            
            <!-- Título -->
            <Label Text="Bienvenido a NStudio" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="#2196F3"
                   Margin="0,40,0,20"/>
            
            <!-- Subtítulo -->
            <Label Text="Inicia sesión para continuar" 
                   FontSize="16" 
                   HorizontalOptions="Center" 
                   TextColor="#666666"
                   Margin="0,0,0,30"/>
            
            <!-- Campo Usuario -->
            <Label Text="Usuario:" 
                   FontSize="14" 
                   TextColor="#333333"/>
            <Entry x:Name="txtUsuario"
                   Placeholder="Ingresa tu usuario"
                   BackgroundColor="White"
                   HeightRequest="50"
                   FontSize="16"/>
            
            <!-- Campo Contraseña -->
            <Label Text="Contraseña:" 
                   FontSize="14" 
                   TextColor="#333333"
                   Margin="0,10,0,0"/>
            <Entry x:Name="txtContrasena"
                   Placeholder="Ingresa tu contraseña"
                   IsPassword="True"
                   BackgroundColor="White"
                   HeightRequest="50"
                   FontSize="16"/>
                   
            <StackLayout Orientation="Horizontal" Margin="0,5,0,10">
            	<CheckBox x:Name="ChkPassM"
            	          HorizontalOptions="Start"
            	          CheckedChanged="ChkPassM_CheckedChanged"/>
            	<Label Text="Mostrar Contraseña"
            	       VerticalOptions="Center"
            	       TextColor="Gray"/>
            </StackLayout>
            
            <!-- Botón Iniciar Sesión -->
            <Button x:Name="btnIniciarSesion"
                    Text="INICIAR SESIÓN"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="10"
                    Margin="0,20,0,0"
                    Clicked="btnIniciarSesion_Clicked"/>
            
            <!-- Mensaje de error -->
            <Label x:Name="lblMensaje"
                   TextColor="Red"
                   HorizontalOptions="Center"
                   FontSize="14"
                   IsVisible="False"
                   Margin="0,10,0,0"/>
            
        </StackLayout>
    </ScrollView>
    
</ContentPage>